    <EventList>
      <!-- Commissioning without ILMD data (missing lot/expiration) -->
      <ObjectEvent>
        <eventTime>2024-03-01T08:00:00.000Z</eventTime>
        <eventTimeZoneOffset>-05:00</eventTimeZoneOffset>
        <epcList>
          <epc>urn:epc:id:sgtin:0383745.038009.500001</epc>
          <epc>urn:epc:id:sgtin:0383745.038009.500002</epc>
        </epcList>
        <action>ADD</action>
        <bizStep>urn:epcglobal:cbv:bizstep:commissioning</bizStep>
        <disposition>urn:epcglobal:cbv:disp:active</disposition>
        <readPoint>
          <id>urn:epc:id:sgln:0383745.00001.0</id>
        </readPoint>
        <bizLocation>
          <id>urn:epc:id:sgln:0383745.00001.0</id>
        </bizLocation>
        <!-- ILMD intentionally missing - DSCSA violation -->
      </ObjectEvent>

      <!-- TransactionEvent: Shipping without required TI elements -->
      <TransactionEvent>
        <eventTime>2024-03-01T14:00:00.000Z</eventTime>
        <eventTimeZoneOffset>-05:00</eventTimeZoneOffset>
        <bizTransactionList>
          <!-- Missing purchase order - only has desadv -->
