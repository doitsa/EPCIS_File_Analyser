      <ObjectEvent>
        <eventTime>2024-03-05T12:00:00.000Z</eventTime>
        <!-- Missing eventTimeZoneOffset -->
        <epcList>
          <epc>urn:epc:id:sgtin:0383745.038009.500001</epc>
        </epcList>
        <action>DELETE</action>
        <bizStep>urn:epcglobal:cbv:bizstep:destroying</bizStep>
        <disposition>urn:epcglobal:cbv:disp:destroyed</disposition>
        <readPoint>
          <id>urn:epc:id:sgln:0614141.00001.0</id>
        </readPoint>
      </ObjectEvent>
    </EventList>
